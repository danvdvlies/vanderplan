# Copy to .env for local development. Never commit the real .env.

# Security
SECRET_KEY=dev-insecure-change-me-in-production
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# Database
# SQLite (local default):
DATABASE_URL=sqlite:///db.sqlite3
# PostgreSQL (hosted):
# DATABASE_URL=postgres://user:password@host:5432/dbname

# When behind HTTPS termination in production, set these to True
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# Self-service signup (keep False for a private family install)
ALLOW_REGISTRATION=True

# Brute-force login protection (django-axes)
AXES_ENABLED=True
AXES_FAILURE_LIMIT=5

# Email (password-reset links). Dev prints to console; set SMTP for production.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=apikey
# EMAIL_HOST_PASSWORD=change-me
# EMAIL_USE_TLS=True
# DEFAULT_FROM_EMAIL=Vanderplan <noreply@yourdomain>
# CSRF_TRUSTED_ORIGINS=https://yourdomain
